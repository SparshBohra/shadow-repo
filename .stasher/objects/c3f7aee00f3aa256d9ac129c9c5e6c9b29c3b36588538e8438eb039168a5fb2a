use anyhow::{Context, Result};
use fastembed::{TextEmbedding, InitOptions, EmbeddingModel};
use lancedb::query::{ExecutableQuery, QueryBase};
use lancedb::{Table, Connection};
use serde::{Deserialize, Serialize};
use std::sync::Arc;
use arrow_array::{RecordBatch, StringArray, Float32Array};
use arrow_schema::{DataType, Field, Schema};

#[derive(Debug, Serialize, Deserialize)]
pub struct SearchRecord {
    pub snapshot_id: String,
    pub file_path: String,
    pub content: String,
    pub vector: Vec<f32>,
}

pub struct SearchEngine {
    model: Arc<TextEmbedding>,
    lancedb: Connection,
}

impl SearchEngine {
    pub async fn new(lancedb: Connection) -> Result<Self> {
        let model = TextEmbedding::try_new(InitOptions {
            model_name: EmbeddingModel::NomicEmbedTextV1_5,
            show_download_progress: true,
            ..Default::default()
        })?;

        Ok(Self {
            model: Arc::new(model),
            lancedb,
        })
    }

    pub async fn get_or_create_table(&self) -> Result<Arc<Table>> {
        let table_names = self.lancedb.table_names().await?;
        if table_names.contains(&"snapshots_v1".to_string()) {
            Ok(Arc::new(self.lancedb.open_table("snapshots_v1").execute().await?))
        } else {
            // For MVP, we'll let it auto-create or define a simple schema
            // LanceDB Rust SDK can create from a batch of records
            Err(anyhow::anyhow!("Table not initialized"))
        }
    }

    pub async fn index_snapshot(&self, snapshot_id: String, file_path: String, content: String) -> Result<()> {
        let embeddings = self.model.embed(vec![content.clone()], None)?;
        let vector = embeddings[0].clone();

        let record = SearchRecord {
            snapshot_id,
            file_path,
            content,
            vector,
        };

        let table_names = self.lancedb.table_names().await?;
        if table_names.contains(&"snapshots_v1".to_string()) {
            let table = self.lancedb.open_table("snapshots_v1").execute().await?;
            table.add(vec![record]).execute().await?;
        } else {
            self.lancedb
                .create_table("snapshots_v1", vec![record])
                .execute()
                .await?;
        }

        Ok(())
    }

    pub async fn search(&self, query: String, limit: usize) -> Result<Vec<SearchRecord>> {
        let query_vec = self.model.embed(vec![query], None)?[0].clone();
        
        let table = self.lancedb.open_table("snapshots_v1").execute().await?;
        let results = table
            .vector_search(query_vec)?
            .limit(limit)
            .execute()
            .await?;
            
        let mut records = Vec::new();
        for batch in results {
            let snapshot_ids = batch.column_by_name("snapshot_id")
                .context("Missing snapshot_id column")?
                .as_any().downcast_ref::<arrow_array::StringArray>()
                .context("Failed to downcast snapshot_id")?;
            
            let file_paths = batch.column_by_name("file_path")
                .context("Missing file_path column")?
                .as_any().downcast_ref::<arrow_array::StringArray>()
                .context("Failed to downcast file_path")?;
            
            let contents = batch.column_by_name("content")
                .context("Missing content column")?
                .as_any().downcast_ref::<arrow_array::StringArray>()
                .context("Failed to downcast content")?;

            for i in 0..batch.num_rows() {
                records.push(SearchRecord {
                    snapshot_id: snapshot_ids.value(i).to_string(),
                    file_path: file_paths.value(i).to_string(),
                    content: contents.value(i).to_string(),
                    vector: vec![], // Vector not needed in return for now
                });
            }
        }
            
        Ok(records)
    }
}
